{
  "name": "server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run --exclude \"src/**/*.db.integration.test.ts\" --exclude \"dist/**\"",
    "test:watch": "vitest",
    "test:db:create": "env-cmd -f .env-cmdrc -e testing -- tsx src/db/create-db.ts",
    "test:migrate": "env-cmd -f .env-cmdrc -e testing -- tsx src/db/migrate.ts up",
    "test:db:drop": "env-cmd -f .env-cmdrc -e testing -- tsx src/db/drop-db.ts",
    "test:setup": "pnpm run test:db:create && pnpm run test:migrate",
    "test:db": "env-cmd -f .env-cmdrc -e testing -- vitest run --no-file-parallelism src/db/foundation-schema.db.integration.test.ts src/modules/setup/first-run-setup.db.integration.test.ts src/modules/authentication/session.db.integration.test.ts src/modules/project/project.db.integration.test.ts src/modules/capture-session/capture-session.db.integration.test.ts src/modules/capture-asset/capture-asset.db.integration.test.ts src/modules/capture-event/capture-event.db.integration.test.ts src/modules/guide/guide.db.integration.test.ts src/modules/publish/publish.db.integration.test.ts src/modules/interactive-demo/interactive-demo.db.integration.test.ts src/modules/organization/organization-invites.db.integration.test.ts",
    "test:smoke": "env-cmd -f .env-cmdrc -e testing -- vitest run --no-file-parallelism src/smoke/v1-workflows.db.integration.test.ts",
    "dev": "env-cmd -f .env-cmdrc -e development -- tsx watch --ignore node_modules --ignore .git --ignore .vscode src/index.ts",
    "clean": "rm -rf dist",
    "build": "tsc",
    "start": "node dist/index.js",
    "env:report": "node --no-deprecation --import tsx src/ops/production-env-report.ts",
    "db:create": "env-cmd -f .env-cmdrc -e development -- tsx src/db/create-db.ts",
    "migrate:up": "env-cmd -f .env-cmdrc -e development -- tsx src/db/migrate.ts up",
    "migrate:down": "env-cmd -f .env-cmdrc -e development -- tsx src/db/migrate.ts down",
    "migrate:status": "env-cmd -f .env-cmdrc -e development -- tsx src/db/migrate.ts status",
    "migrate:new": "env-cmd -f .env-cmdrc -e development -- tsx src/db/migrate-new.ts",
    "lint": "eslint .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/constants": "workspace:*",
    "@repo/capture-domain": "workspace:*",
    "@repo/file-domain": "workspace:*",
    "@repo/types": "workspace:*",
    "@casl/ability": "^6.8.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/websocket": "^11.2.0",
    "env-cmd": "^11.0.0",
    "eventemitter3": "^5.0.4",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "pg": "^8.18.0",
    "pg-promise": "^12.6.1",
    "sharp": "^0.33.5",
    "ulid": "^3.0.2",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@scalar/fastify-api-reference": "^1.44.20",
    "@scalar/themes": "^0.14.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.16.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.4",
    "typescript": "5.9.2",
    "vitest": "^4.1.5"
  }
}
